# QuantVista — local environment template. Copy to `.env` (gitignored) and adjust.
# NO REAL SECRETS in this file — it is committed. `.env` is read by docker-compose
# and by pydantic-settings (quantvista.core.config).

# App
APP_ENV=local

# PostgreSQL
# - POSTGRES_* = the admin role the image creates (superuser). Used by `migrate`/`seed`.
# - The app (api/worker/beat) connects as a SEPARATE non-superuser role
#   `quantvista_app` (created by scripts/db/00-create-app-role.sql) so Row-Level
#   Security actually enforces tenant isolation locally — a superuser would bypass it.
POSTGRES_USER=quantvista
POSTGRES_PASSWORD=quantvista
POSTGRES_DB=quantvista
# App connection (non-superuser) — used by api/worker/beat.
DATABASE_URL=postgresql+psycopg://quantvista_app:quantvista_app@postgres:5432/quantvista
# Admin connection (superuser) — used by the migrate one-shot (Alembic).
ADMIN_DATABASE_URL=postgresql+psycopg://quantvista:quantvista@postgres:5432/quantvista

# Redis (cache · Celery broker/result · Streams event bus)
REDIS_URL=redis://redis:6379/0

# Object store (MinIO locally; S3 in cloud). minioadmin/minioadmin are MinIO defaults.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=quantvista-local

# Auth (QV-006). MUST set a strong JWT_SECRET in any non-local environment.
JWT_SECRET=dev-insecure-secret-change-me-in-non-local-environments
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
# Local dev runs over http, so the Secure cookie flag must be off to send the refresh
# cookie. In staging/prod (https) set COOKIE_SECURE=true.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Observability (QV-009). Every backend is optional — leave unset locally and the
# api/worker emit in-process telemetry without shipping anywhere (no collector/Sentry
# needed). Wire the endpoints/DSN via Secrets Manager in staging/prod (PV-003).
LOG_LEVEL=INFO
# Human-readable console logs locally; set true for JSON logs in cloud.
LOG_JSON=false
# OpenTelemetry OTLP collector (Tempo/Jaeger). Unset → traces created but not exported.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_SERVICE_NAME=  # defaults to quantvista-<role>
# Sentry DSN. Unset → Sentry is NOT initialised. NEVER commit a real DSN.
# SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
# Prometheus. /metrics is exposed by the api; the worker serves its registry on this port.
METRICS_ENABLED=true
WORKER_METRICS_PORT=9100
