{# Metric-threshold alert (the one that fires today). Factual: the metric, the current value, and
   the user's own threshold — no buy/sell call, no price target (see the footer disclaimer). #}
{% extends "_base.html.j2" %}
{% block content %}
<p style="margin:0 0 4px; font-size:13px; font-weight:600; text-transform:uppercase; letter-spacing:0.6px; color:#2f5aa6;">Alert triggered</p>
<h1 style="margin:0 0 20px; font-size:22px; line-height:28px; font-weight:700; color:#1a2233;">
  {{ symbol }}{% if company_name %} <span style="font-weight:400; color:#6b7688;">&middot; {{ company_name }}</span>{% endif %}
</h1>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f6f8fb; border:1px solid #e6ecf5; border-radius:10px;">
  <tr>
    <td style="padding:20px 24px;">
      <p style="margin:0 0 6px; font-size:14px; color:#6b7688;">{{ metric_label }}</p>
      <p style="margin:0; font-size:32px; line-height:36px; font-weight:700; color:#1e3a6b;">{{ value_display }}</p>
      <p style="margin:12px 0 0; font-size:14px; color:#4a5568;">
        Your condition: <strong style="color:#1a2233;">{{ metric_label }} {{ op_symbol }} {{ threshold_display }}</strong>
      </p>
    </td>
  </tr>
</table>
<p style="margin:24px 0 0; font-size:15px; line-height:22px; color:#4a5568;">
  {{ symbol }}&rsquo;s {{ metric_label|lower }} is now {{ value_display }}, which is {{ op_words }} your threshold of {{ threshold_display }}.
</p>
<table role="presentation" cellpadding="0" cellspacing="0" style="margin:28px 0 4px;">
  <tr>
    <td style="border-radius:8px; background-color:#2f5aa6;">
      <a href="{{ cta_url }}" style="display:inline-block; padding:12px 28px; font-size:15px; font-weight:600; color:#ffffff; text-decoration:none;">View in QuantVista &rarr;</a>
    </td>
  </tr>
</table>
{% endblock %}
