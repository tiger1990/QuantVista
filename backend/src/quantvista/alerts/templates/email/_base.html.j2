{#
  Base branded email layout (QV-049 enhancement). Provider-portable HTML — sent as-is via any
  IEmailSender (Brevo now, SES later). Email-safe by design: table-based layout + INLINE styles
  (Gmail and others strip <style> blocks), 600px card, brand ink-blue. Child templates fill the
  `content` block; the header logo is a hosted image when `logo_url` is set, else a text wordmark.
#}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ subject }}</title>
</head>
<body style="margin:0; padding:0; background-color:#f4f5f7; -webkit-font-smoothing:antialiased; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif; color:#1a2233;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f5f7;">
    <tr>
      <td align="center" style="padding:32px 16px;">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="max-width:600px; width:100%; background-color:#ffffff; border-radius:12px; overflow:hidden; border:1px solid #e6e8ec;">
          <tr>
            <td style="background-color:#1e3a6b; padding:22px 32px;">
              {% if logo_url %}
              <img src="{{ logo_url }}" alt="{{ from_name }}" height="28" style="height:28px; display:block; border:0; outline:none; text-decoration:none;">
              {% else %}
              <span style="font-size:20px; font-weight:700; letter-spacing:0.5px; color:#ffffff;">QUANT<span style="color:#7fa8e6;">VISTA</span></span>
              {% endif %}
            </td>
          </tr>
          <tr>
            <td style="padding:32px;">
              {% block content %}{% endblock %}
            </td>
          </tr>
          <tr>
            <td style="padding:22px 32px; border-top:1px solid #eef0f3; background-color:#fafbfc;">
              <p style="margin:0 0 12px; font-size:12px; line-height:18px; color:#8a94a6;">{{ disclaimer }}</p>
              <p style="margin:0; font-size:12px; line-height:18px; color:#8a94a6;">
                <a href="{{ manage_url }}" style="color:#2f5aa6; text-decoration:none;">Manage your alerts</a>
                &nbsp;&middot;&nbsp; QuantVista &mdash; India-first equity research
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
